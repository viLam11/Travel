# Travello — Production Environment Variables
# Copy this file to .env and fill in real values before deploying.
# ⚠️  NEVER commit .env to Git — only commit .env.example

# ─── Frontend (Vite build args) ────────────────────────────────────────────
# The public URL of your deployed Spring Boot backend API
VITE_API_DEPLOY_URL=http://YOUR_BACKEND_IP:8080

# Mapbox public token (safe to expose in frontend builds)
VITE_MAPBOX_TOKEN=pk.eyJ1...your_token_here
